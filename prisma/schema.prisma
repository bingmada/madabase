generator client {
  provider = "prisma-client"
  output   = "../apps/web/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum CreditTransactionType {
  grant
  consume
  refund
  adjustment
}

model User {
  id                String                  @id @default(cuid())
  email             String                  @unique
  emailVerified     Boolean                 @default(false)
  avatar            String?
  nickname          String?
  locale            String                  @default("en")
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  sessions          Session[]
  favorites         Favorite[]
  toolUsages        ToolUsage[]
  credits           Credit?
  creditTransactions CreditTransaction[]
  testAttempts      TestAttempt[]
  unlocks           UserUnlock[]
  testShareLinks    TestShareLink[]         @relation("TestShareLinks")
  referralRewardsGiven ReferralReward[]     @relation("ReferralRewardsGiven")
  referralRewardsReceived ReferralReward[]  @relation("ReferralRewardsReceived")
  verificationCodes EmailVerificationCode[]
}

model Session {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationCode {
  id         String   @id @default(cuid())
  userId     String?
  email      String
  code       String
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email, expiresAt])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  toolSlug  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolSlug])
  @@index([toolSlug])
}

model ToolUsage {
  id         String   @id @default(cuid())
  userId      String
  toolSlug    String
  count       Int      @default(0)
  lastUsedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolSlug])
  @@index([toolSlug, lastUsedAt])
}

model Credit {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CreditTransaction {
  id        String                @id @default(cuid())
  userId    String
  amount    Int
  type      CreditTransactionType
  description String?
  createdAt DateTime              @default(now())
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model UserUnlock {
  id         String   @id @default(cuid())
  userId     String
  testSlug   String
  resultType String
  attemptId  String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, testSlug, resultType, attemptId])
  @@index([testSlug, resultType])
  @@index([userId, attemptId])
}

model TestAttempt {
  id         String   @id @default(cuid())
  userId     String
  testSlug   String
  resultType String
  attemptId  String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, attemptId])
  @@index([userId, createdAt])
  @@index([testSlug, resultType])
}

model TestShareLink {
  id        String           @id @default(cuid())
  code      String           @unique
  userId    String
  testSlug  String
  createdAt DateTime         @default(now())
  user      User             @relation("TestShareLinks", fields: [userId], references: [id], onDelete: Cascade)
  rewards   ReferralReward[]

  @@unique([userId, testSlug])
  @@index([testSlug])
}

model ReferralReward {
  id             String        @id @default(cuid())
  shareLinkId    String
  referrerUserId String
  referredUserId String
  testSlug       String
  resultType     String
  amount         Int
  createdAt      DateTime      @default(now())
  shareLink      TestShareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  referrer       User          @relation("ReferralRewardsGiven", fields: [referrerUserId], references: [id], onDelete: Cascade)
  referred       User          @relation("ReferralRewardsReceived", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@unique([shareLinkId, referredUserId])
  @@index([referrerUserId, createdAt])
  @@index([referredUserId, createdAt])
}
